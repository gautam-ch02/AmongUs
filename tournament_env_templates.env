# Copy one RUN block at a time into .env (replace model IDs if needed for your provider account).
# Keep the shared/base block in every run.

############################
# SHARED BASE (ALL RUNS)
############################
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_TIMEOUT_SECONDS=60
TOURNAMENT_ID=tourn_v1
TOURNAMENT_NOTES=single_human_tournament

############################################################
# RUN_001 done
############################################################
TOURNAMENT_CELL=H_CREW_FRONTIER
TOURNAMENT_RUN_LABEL=RUN_001
TOURNAMENT_HUMAN_ROLE=crewmate
OPENROUTER_CREWMATE_MODEL=openai/gpt-5-mini
OPENROUTER_IMPOSTOR_MODEL=openai/gpt-5-mini

############################################################
# RUN_002
############################################################
TOURNAMENT_CELL=H_IMP_FRONTIER
TOURNAMENT_RUN_LABEL=RUN_002
TOURNAMENT_HUMAN_ROLE=impostor
